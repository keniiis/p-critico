---
import Layout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

import newsJson from "../../data/news.json";

export function getStaticPaths() {
    return Object.keys(newsJson).map((slug) => ({
        params: { slug },
    }));
}

const { slug } = Astro.params;

interface NewsBlock {
    type: "paragraph" | "heading" | "list" | "quote" | "hr";
    text?: string;
    items?: string[];
    level?: number;
}

interface NewsArticle {
    title: string;
    category: string;
    date: string;
    image: string;
    author: string;
    summary: string;
    variant: string;
    content: NewsBlock[];
}

const article = (newsJson as Record<string, NewsArticle>)[slug as string];

// ── PARSER: mismo sistema que el editor preview ──────────────────────────
function parseInline(text: string = ""): string {
    return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="article-link">$1</a>');
}

function renderBlocks(blocks: NewsBlock[]): string {
    let html = '';
    for (const block of blocks) {
        if (block.type === 'paragraph') {
            const txt = block.text ?? '';
            if (!txt.trim() || txt.trim() === '---') continue;
            html += `<p class="article-p">${parseInline(txt)}</p>`;
        } else if (block.type === 'heading') {
            const lvl = block.level ?? 2;
            const cls = lvl <= 2 ? 'article-h2' : lvl === 3 ? 'article-h3' : 'article-h4';
            html += `<h${lvl} class="${cls}">${parseInline(block.text ?? '')}</h${lvl}>`;
        } else if (block.type === 'quote') {
            html += `<blockquote class="article-quote">${parseInline(block.text ?? '')}</blockquote>`;
        } else if (block.type === 'list') {
            const items = (block.items ?? []).map(i => `<li class="article-li"><span class="article-bullet">—</span><span>${parseInline(i)}</span></li>`).join('');
            html += `<ul class="article-ul">${items}</ul>`;
        } else if (block.type === 'hr') {
            html += `<hr class="article-hr">`;
        }
    }
    return html;
}

const contentHtml = renderBlocks(article.content);

// Función para convertir "05 MAYO, 2026" a "2026-05-05" para Google
function getISODate(dateStr: string) {
    try {
        const months: Record<string, string> = {
            'ENERO': '01', 'FEBRERO': '02', 'MARZO': '03', 'ABRIL': '04',
            'MAYO': '05', 'JUNIO': '06', 'JULIO': '07', 'AGOSTO': '08',
            'SEPTIEMBRE': '09', 'OCTUBRE': '10', 'NOVIEMBRE': '11', 'DICIEMBRE': '12'
        };
        const parts = dateStr.toUpperCase().replace(',', '').split(' ');
        if (parts.length === 3) {
            const day = parts[0].padStart(2, '0');
            const month = months[parts[1]] || '01';
            const year = parts[2];
            return `${year}-${month}-${day}`;
        }
    } catch (e) {
        return '';
    }
    return '';
}

const isoDate = getISODate(article.date);
---

<Layout title={`${article.title} - Noticias de Paralaje Crítico`}>
    <Navbar active="news" />

    <main class="flex-grow pt-32 pb-24">
        <article class="max-w-4xl mx-auto px-margin">
            <!-- Header -->
            <header class="mb-12">
                <div class="flex items-center gap-3 mb-6">
                    <span class="glass-panel px-3 py-1 rounded-full font-label-caps text-[10px] text-primary-container uppercase tracking-widest"
                        >{article.category}</span
                    >
                    <time datetime={isoDate} class="text-tertiary font-label-caps text-[10px] uppercase tracking-widest"
                        >{article.date}</time
                    >
                </div>
                <h1 class="font-display-lg text-display-lg text-on-surface leading-tight mb-8 text-gradient">
                    {article.title}
                </h1>
                <div class="flex items-center gap-4 py-6 border-y border-white/10">
                    <div class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface font-bold">
                        C
                    </div>
                    <div>
                        <span class="block text-on-surface font-headline-md text-sm">{article.author}</span>
                        <span class="text-tertiary text-xs uppercase tracking-widest font-label-caps">Team Paralaje Crítico</span>
                    </div>
                </div>
            </header>

            <!-- Featured Image -->
            <div class="aspect-video rounded-2xl overflow-hidden mb-16 border border-white/10 shadow-2xl">
                <img src={article.image} alt={article.title} class="w-full h-full object-cover" />
            </div>

            <!-- Content -->
            <div class="article-body" set:html={contentHtml} />

            <!-- Share / Footer -->
            <footer class="mt-20 pt-10 border-t border-white/10 flex items-center justify-between">
                <div class="flex gap-4">
                    <button class="glass-panel p-3 rounded-full text-tertiary hover:text-on-surface transition-colors">
                        <span class="material-symbols-outlined">share</span>
                    </button>
                </div>
                <a href="/" class="font-label-caps text-label-caps text-tertiary hover:text-on-surface transition-colors uppercase tracking-widest flex items-center gap-2">
                    Volver al inicio
                    <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </a>
            </footer>
        </article>
    </main>

    <Footer />
</Layout>

<style is:global>
    /* ── ESTILOS ARTÍCULO (idénticos al preview del editor) ────────────── */
    .article-body { max-width: none; }

    .article-p {
        color: #d1d1d1;
        line-height: 1.8;
        margin-bottom: 1.25rem;
        font-size: 1.125rem;
    }

    .article-h2 {
        font-size: 1.875rem;
        font-weight: 800;
        color: #ffffff;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        line-height: 1.2;
    }
    .article-h3 {
        font-size: 1.4rem;
        font-weight: 800;
        color: #ffffff;
        margin-top: 2rem;
        margin-bottom: 0.65rem;
        line-height: 1.2;
    }
    .article-h4 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #e5e5e5;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .article-quote {
        border-left: 4px solid #f43f5e;
        padding: 0.75rem 1.25rem;
        background: rgba(244, 63, 94, 0.08);
        border-radius: 0 0.75rem 0.75rem 0;
        color: #fda4af;
        font-style: italic;
        margin: 1.5rem 0;
        font-size: 1.125rem;
        line-height: 1.7;
    }

    .article-hr {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.12);
        margin: 2rem 0;
    }

    .article-ul {
        list-style: none;
        padding: 0;
        margin-bottom: 1.5rem;
    }
    .article-li {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 0.6rem;
        color: #d1d1d1;
        font-size: 1.05rem;
        line-height: 1.7;
    }
    .article-li > span:last-child {
        flex: 1;
        min-width: 0;
        overflow-wrap: break-word;
    }
    .article-bullet {
        color: #f43f5e;
        font-weight: 700;
        flex-shrink: 0;
    }

    .article-body strong { color: #ffffff; font-weight: 700; }
    .article-body em    { color: #fda4af; font-style: italic; }
    .article-link       { color: #f43f5e; text-decoration: underline; }
    .article-link:hover { color: #fda4af; }
</style>
