                { id: 'platform_appletv', name: 'Apple TV', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_prime', name: 'Prime Video', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' }
            ];
            const watchOptions: any[] = [];
            for (const plat of platformMappings) {
                if (formData.get(plat.id) === 'on') watchOptions.push({ name: plat.name, logo: plat.logo });
            }
            const castRaw = getString('cast');
            const cast = castRaw.split('\n').filter((l: string) => l.includes(' como ')).map((l: string) => {
                const [actor, role] = l.split(' como ');
                return { actor: actor.trim(), role: role.trim() };
            });

            const updatedData = {
                title: getString('title'), subtitle: getString('subtitle'),
                rating: getNum('rating'), year: getString('year'),
                director: getString('director'), duration: getString('duration'),
                date: getString('date'), genre: getString('genre'),
                heroImage: getString('heroImage'), posterImage: getString('posterImage'),
                author: getString('author'), trailerUrl: getString('trailerUrl'),
                fullReview: getString('fullReview').split('\n\n').map((p: string) => p.trim()).filter((p: string) => p),
                finalScore: getString('finalScore'), streaming: getString('streaming'),
                scores: [
                    { category: 'Fotografía',   score: getNum('score_foto'),       icon: 'movie_filter', desc: getString('desc_foto') },
                    { category: 'Actuación',     score: getNum('score_actuacion'),  icon: 'groups',       desc: getString('desc_actuacion') },
                    { category: 'Banda Sonora',  score: getNum('score_sonido'),     icon: 'audiotrack',   desc: getString('desc_sonido') },
                    { category: 'Guion',         score: getNum('score_guion'),      icon: 'auto_stories', desc: getString('desc_guion') }
                ],
                cast, watchOptions
            };

            try {
                const res = await fetch('/api/update-review', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ slug: editSlug, data: updatedData })
                });
                const result = await res.json();
                if (result.success) {
                    statusMsg!.textContent = '¡Reseña actualizada con éxito!';
                    statusMsg!.className = 'text-center mt-4 text-sm font-bold text-green-400 transition-opacity opacity-100';
                    editSlugInput.value = '';
                    setTimeout(() => { window.location.href = `/reviews/${editSlug}`; }, 1500);
                } else { throw new Error(result.error); }
            } catch (err) {
                statusMsg!.textContent = 'Error: ' + (err instanceof Error ? err.message : String(err));
                statusMsg!.className = 'text-center mt-4 text-sm font-bold text-red-400 transition-opacity opacity-100';
                submitBtn.innerHTML = originalBtnText;
                submitBtn.style.opacity = '1';
                submitBtn.style.pointerEvents = 'all';
            }
        }, true); // capture:true para ejecutarse antes del handler original
    }
</script>
