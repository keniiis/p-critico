---
import Layout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Esta página solo debería estar accesible en entorno local por seguridad
const isDev = import.meta.env.DEV;
---

<Layout title="Admin Panel - Paralaje Crítico">
    <Navbar />
    
    <style is:global>
        #md-preview p {
            color: #a8a8a8 !important;
            line-height: 1.8 !important;
            margin-bottom: 1.5rem !important;
            font-size: 1rem !important;
            display: block !important;
        }
        #md-preview strong {
            color: #ffffff !important;
            font-weight: 700 !important;
        }

        /* --- ESTILO DE SCROLLBARS PREMIUM (VIOLETA) --- */
        #md-editor::-webkit-scrollbar, 
        #md-preview::-webkit-scrollbar {
            width: 8px;
        }
        #md-editor::-webkit-scrollbar-track, 
        #md-preview::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.2);
        }
        #md-editor::-webkit-scrollbar-thumb, 
        #md-preview::-webkit-scrollbar-thumb {
            background: rgba(167, 139, 250, 0.3);
            border-radius: 10px;
            border: 2px solid transparent;
            background-clip: content-box;
        }
        #md-editor::-webkit-scrollbar-thumb:hover, 
        #md-preview::-webkit-scrollbar-thumb:hover {
            background: rgba(167, 139, 250, 0.6);
        }
    </style>

    <main class="grow pt-32 pb-20">
        <div class="max-w-[1600px] mx-auto px-margin">
            
            {!isDev ? (
                <div class="glass-panel p-12 text-center rounded-3xl border border-red-500/20 max-w-3xl mx-auto">
                    <span class="material-symbols-outlined text-5xl text-red-400 mb-6">gpp_bad</span>
                    <h1 class="font-display-lg text-3xl text-on-surface mb-4">Acceso Denegado</h1>
                    <p class="text-tertiary">El panel de administración solo está disponible en el entorno de desarrollo local (npm run dev).</p>
                </div>
            ) : (
                <>
                    <header class="mb-16 text-center max-w-5xl mx-auto">
                        <div class="inline-flex items-center gap-2 glass-panel px-4 py-2 rounded-full text-primary-container font-label-caps text-[11px] tracking-widest uppercase mb-6">
                            <span class="material-symbols-outlined text-[16px]">admin_panel_settings</span>
                            Paralaje Crítico CMS
                        </div>
                        <h1 class="font-display-lg text-5xl text-on-surface text-gradient mb-6 leading-tight">Gestor de Contenido</h1>
                        <p class="text-tertiary font-body-lg text-lg mb-8">Rellena el formulario para publicar una nueva película en el catálogo.</p>
                        
                        <!-- Pestañas de Navegación -->
                        <div class="flex items-center justify-center gap-4">
                            <a href="/admin" class="px-8 py-3 rounded-full text-xs font-bold tracking-widest uppercase transition-colors bg-primary-container text-background">Nueva Reseña</a>
                            <a href="/admin/news" class="px-8 py-3 rounded-full text-xs font-bold tracking-widest uppercase transition-colors glass-panel text-tertiary hover:text-on-surface border border-transparent hover:border-white/10">Nueva Noticia</a>
                            <button type="button" id="tab-gestionar" class="px-8 py-3 rounded-full text-xs font-bold tracking-widest uppercase transition-colors glass-panel text-tertiary hover:text-on-surface border border-transparent hover:border-white/10">Gestionar</button>
                        </div>
                    </header>

                    <!-- Panel Gestionar -->
                    <div id="gestionar-panel" class="hidden space-y-6 mb-16">
                        <h2 class="font-display-lg text-3xl text-on-surface text-center mb-4">Contenido Publicado</h2>

                        <!-- Sub-pestañas -->
                        <div class="flex items-center justify-center gap-4 mb-8">
                            <button id="sub-tab-reviews" class="px-6 py-2.5 rounded-full text-xs font-bold tracking-widest uppercase transition-colors bg-primary-container text-background">Reseñas</button>
                            <button id="sub-tab-news" class="px-6 py-2.5 rounded-full text-xs font-bold tracking-widest uppercase transition-colors glass-panel text-tertiary hover:text-on-surface border border-white/10">Noticias</button>
                        </div>

                        <!-- Lista Reseñas -->
                        <div id="reviews-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            <div class="text-tertiary text-center py-10 col-span-3">Cargando reseñas...</div>
                        </div>

                        <!-- Lista Noticias (oculta por defecto) -->
                        <div id="news-list-gestionar" class="hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            <div class="text-tertiary text-center py-10 col-span-3">Cargando noticias...</div>
                        </div>
                    </div>

                    <!-- Campo oculto para modo edición -->
                    <input type="hidden" id="edit-slug" value="" />

                    <form id="review-form" class="space-y-12 max-w-none">
                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                            <!-- Columna Izquierda (Contenido y Detalles) -->
                            <div class="lg:col-span-7 space-y-12">
                                <!-- Sección: Información Básica -->
                                <section class="glass-panel p-10 md:p-12 rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-primary-container"></div>
                                    <h2 class="font-headline-md text-2xl text-on-surface mb-8">Información de la Obra</h2>
                                    
                                    <div class="space-y-8">
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Título de la Película / Serie</label>
                                            <input required type="text" name="title" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors font-bold text-lg" placeholder="Ej: Oppenheimer" />
                                        </div>
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Subtítulo o Gancho</label>
                                            <input required type="text" name="subtitle" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors" placeholder="Ej: El hombre que movió el mundo" />
                                        </div>
                                        
                                        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Nota (0-10)</label>
                                                <input required type="number" step="0.1" name="rating" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-center font-bold" placeholder="8.5" />
                                            </div>
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Año</label>
                                                <input required type="text" name="year" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-center" placeholder="2023" />
                                            </div>
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Duración</label>
                                                <input required type="text" name="duration" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-center" placeholder="180 min" />
                                            </div>
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Género</label>
                                                <input required type="text" name="genre" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-center" placeholder="Drama" />
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <!-- Sección: Editor Visual -->
                                <section class="glass-panel rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-tertiary"></div>
                                    <div class="flex items-center justify-between px-8 pt-8 pb-4 border-b border-white/10">
                                        <h2 class="font-headline-md text-2xl text-on-surface">Cuerpo de la Crítica</h2>
                                        <button type="button" id="toggle-preview" class="px-4 py-1.5 rounded-lg bg-primary-container text-background text-xs font-bold uppercase tracking-widest hover:bg-white transition-colors flex items-center gap-1.5">
                                            <span class="material-symbols-outlined text-[14px]">visibility</span> Vista Previa
                                        </button>
                                    </div>

                                    <!-- Editor Split Pane con bloqueo de altura -->
                                    <div id="editor-container" class="grid grid-cols-2 divide-x divide-white/10" style="height: 700px; max-height: 700px; overflow: hidden;">
                                        <!-- Panel Izquierdo: Editor -->
                                        <div class="flex flex-col h-full bg-black/10" style="height: 700px;">
                                            <div class="px-4 py-2 bg-white/5 border-b border-white/5 flex items-center gap-2 flex-none">
                                                <span class="w-2 h-2 rounded-full bg-[#a78bfa] animate-pulse"></span>
                                                <span class="text-tertiary text-[10px] font-label-caps tracking-widest uppercase">Crítica MD</span>
                                            </div>
                                            <textarea
                                                required
                                                name="review"
                                                id="md-editor"
                                                class="w-full h-full bg-transparent px-10 py-8 text-on-surface focus:outline-none font-mono text-sm leading-relaxed resize-none"
                                                style="overflow-y: scroll !important; height: calc(700px - 40px); display: block;"
                                                placeholder="Escribe tu crítica aquí..."></textarea>
                                        </div>

                                        <!-- Panel Derecho: Preview -->
                                        <div class="flex flex-col h-full bg-surface-container/30" style="height: 700px;">
                                            <div class="px-4 py-2 bg-white/5 border-b border-white/5 flex items-center gap-2 flex-none">
                                                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                                <span class="text-tertiary text-[10px] font-label-caps tracking-widest uppercase">Vista Previa</span>
                                            </div>
                                            <div id="md-preview" class="px-12 py-10 prose-preview" style="height: calc(700px - 40px); overflow-y: scroll !important; background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 32px 32px; display: block;">
                                                <p class="text-tertiary text-sm italic">Tu crítica aparecerá aquí con formato real...</p>
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <!-- Sección: Elenco y Firma -->
                                <section class="glass-panel p-10 md:p-12 rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-primary-container"></div>
                                    <div class="space-y-8">
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Elenco (Uno por línea: Actor como Personaje)</label>
                                            <textarea name="cast" rows="5" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-6 py-5 text-on-surface focus:outline-none focus:border-primary-container transition-colors font-mono text-sm" placeholder="Karl Urban como Johnny Cage"></textarea>
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Nota Final (0 a 10)</label>
                                                <input required type="text" name="finalScore" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-primary-container font-bold text-lg focus:outline-none focus:border-primary-container transition-colors" placeholder="8.5" />
                                            </div>
                                            <div>
                                                <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Firma del Autor</label>
                                                <input required type="text" name="author" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors" value="Paralaje Crítico" />
                                            </div>
                                        </div>
                                    </div>
                                </section>
                            </div>

                            <!-- Columna Derecha (Imágenes y Análisis Técnico) -->
                            <div class="lg:col-span-5 space-y-12">
                                <!-- Sección: Imágenes -->
                                <section class="glass-panel p-10 md:p-12 rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-secondary-container"></div>
                                    <h2 class="font-headline-md text-2xl text-on-surface mb-8">Archivos Multimedia</h2>
                                    <div class="space-y-8">
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Cabecera (Hero) - Panorámica</label>
                                            <input required type="text" name="heroImage" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors font-mono text-sm" placeholder="/images/reviews/tu-imagen.jpg" />
                                        </div>
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Póster (Tarjeta) - Vertical</label>
                                            <input required type="text" name="posterImage" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors font-mono text-sm" placeholder="/images/reviews/tu-poster.jpg" />
                                        </div>
                                        <div>
                                            <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">URL del Tráiler (YouTube)</label>
                                            <input type="text" name="trailerUrl" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors font-mono text-sm" placeholder="https://www.youtube.com/watch?v=..." />
                                        </div>
                                    </div>
                                </section>

                                <!-- Sección: Disponibilidad -->
                                <section class="glass-panel p-10 md:p-12 rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-[#3b82f6]"></div>
                                    <h2 class="font-headline-md text-2xl text-on-surface mb-8">Disponibilidad</h2>
                                    
                                    <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-4">Plataformas donde verla</label>
                                    <div class="grid grid-cols-2 gap-4">
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_cines" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Cines</span>
                                        </label>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_netflix" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Netflix</span>
                                        </label>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_max" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Max</span>
                                        </label>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_disney" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Disney+</span>
                                        </label>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_appletv" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Apple TV</span>
                                        </label>
                                        <label class="flex items-center gap-3 cursor-pointer group">
                                            <input type="checkbox" name="platform_prime" class="w-5 h-5 rounded border-white/20 bg-surface-container-high text-primary-container focus:ring-primary-container focus:ring-offset-background" />
                                            <span class="text-on-surface text-sm group-hover:text-primary-container transition-colors">Prime Video</span>
                                        </label>
                                    </div>
                                    <div class="mt-8">
                                        <label class="block text-tertiary font-label-caps text-[11px] uppercase tracking-widest mb-3">Texto Resumen (Ej: "Cines / Max")</label>
                                        <input type="text" name="streaming" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors" placeholder="Cines / Netflix" />
                                    </div>
                                </section>

                                <!-- Sección: Análisis Técnico (Desglose) -->
                                <section class="glass-panel p-10 md:p-12 rounded-3xl border border-white/10 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1.5 h-full bg-[#4ade80]"></div>
                                    <h2 class="font-headline-md text-2xl text-on-surface mb-8">Desglose del Puntaje</h2>
                                    
                                    <div class="space-y-10">
                                        <!-- Fotografía -->
                                        <div>
                                            <div class="flex items-center gap-4 mb-4">
                                                <span class="material-symbols-outlined text-tertiary text-xl">movie_filter</span>
                                                <label class="block text-on-surface font-label-caps text-[11px] uppercase tracking-widest grow">Fotografía</label>
                                                <input required type="number" step="0.1" name="score_foto" class="w-20 bg-surface-container-high border border-white/10 rounded-lg px-3 py-2 text-on-surface text-center focus:outline-none focus:border-primary-container text-sm font-bold" placeholder="9.0" />
                                            </div>
                                            <textarea required name="desc_foto" rows="3" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-sm leading-relaxed" placeholder="Análisis visual..."></textarea>
                                        </div>
                                        
                                        <!-- Actuación -->
                                        <div>
                                            <div class="flex items-center gap-4 mb-4">
                                                <span class="material-symbols-outlined text-tertiary text-xl">groups</span>
                                                <label class="block text-on-surface font-label-caps text-[11px] uppercase tracking-widest grow">Actuación</label>
                                                <input required type="number" step="0.1" name="score_actuacion" class="w-20 bg-surface-container-high border border-white/10 rounded-lg px-3 py-2 text-on-surface text-center focus:outline-none focus:border-primary-container text-sm font-bold" placeholder="9.5" />
                                            </div>
                                            <textarea required name="desc_actuacion" rows="3" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-sm leading-relaxed" placeholder="Interpretaciones..."></textarea>
                                        </div>

                                        <!-- Banda Sonora -->
                                        <div>
                                            <div class="flex items-center gap-4 mb-4">
                                                <span class="material-symbols-outlined text-tertiary text-xl">audiotrack</span>
                                                <label class="block text-on-surface font-label-caps text-[11px] uppercase tracking-widest grow">Banda Sonora</label>
                                                <input required type="number" step="0.1" name="score_sonido" class="w-20 bg-surface-container-high border border-white/10 rounded-lg px-3 py-2 text-on-surface text-center focus:outline-none focus:border-primary-container text-sm font-bold" placeholder="9.2" />
                                            </div>
                                            <textarea required name="desc_sonido" rows="3" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-sm leading-relaxed" placeholder="Música y mezcla..."></textarea>
                                        </div>

                                        <!-- Guion -->
                                        <div>
                                            <div class="flex items-center gap-4 mb-4">
                                                <span class="material-symbols-outlined text-tertiary text-xl">auto_stories</span>
                                                <label class="block text-on-surface font-label-caps text-[11px] uppercase tracking-widest grow">Guion</label>
                                                <input required type="number" step="0.1" name="score_guion" class="w-20 bg-surface-container-high border border-white/10 rounded-lg px-3 py-2 text-on-surface text-center focus:outline-none focus:border-primary-container text-sm font-bold" placeholder="8.5" />
                                            </div>
                                            <textarea required name="desc_guion" rows="3" class="w-full bg-surface-container-high border border-white/10 rounded-xl px-5 py-4 text-on-surface focus:outline-none focus:border-primary-container transition-colors text-sm leading-relaxed" placeholder="Narrativa y diálogos..."></textarea>
                                        </div>
                                    </div>
                                </section>
                            </div>
                        </div>

                        <!-- Botón Submit -->
                        <div class="pt-6 max-w-lg mx-auto">
                            <button type="submit" id="submit-btn" class="w-full py-4 bg-primary-container hover:bg-white text-background font-label-caps uppercase tracking-widest rounded-xl transition-all font-bold text-lg flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">save</span>
                                Publicar Reseña
                            </button>
                            <p id="status-msg" class="text-center mt-4 text-sm font-bold opacity-0 transition-opacity"></p>
                        </div>
                    </form>
                </>
            )}
        </div>
    </main>
    <Footer />
</Layout>

<script>
    const form = document.getElementById('review-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const statusMsg = document.getElementById('status-msg') as HTMLParagraphElement | null;

        // ── EDITOR VISUAL (RESEÑAS) ───────────────────────────────────
        const mdEditor      = document.getElementById('md-editor') as HTMLTextAreaElement | null;
        const mdPreview     = document.getElementById('md-preview') as HTMLElement | null;
        const toggleBtn     = document.getElementById('toggle-preview') as HTMLButtonElement | null;
        const editorContainer = document.getElementById('editor-container') as HTMLElement | null;

        function renderPreview(text: string): string {
            if (!text.trim()) return '<p class="text-tertiary text-sm italic">Tu crítica se verá así...</p>';
            const paragraphs = text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p);
            return paragraphs.map(p => {
                const parsed = p.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                return `<p>${parsed}</p>`;
            }).join('');
        }

        if (mdEditor && mdPreview) {
            mdEditor.addEventListener('input', () => {
                mdPreview.innerHTML = renderPreview(mdEditor.value);
            });

            // Proxy para detectar cambios programáticos (cuando se edita una reseña existente)
            const origDescriptor = Object.getOwnPropertyDescriptor(HTMLTextAreaElement.prototype, 'value');
            if (origDescriptor) {
                Object.defineProperty(mdEditor, 'value', {
                    set(v) {
                        origDescriptor.set!.call(this, v);
                        mdPreview.innerHTML = renderPreview(v);
                    },
                    get() { return origDescriptor.get!.call(this); }
                });
            }
        }

        let splitMode = true;
        toggleBtn?.addEventListener('click', () => {
            splitMode = !splitMode;
            if (editorContainer) {
                editorContainer.className = splitMode ? 'grid grid-cols-2 divide-x divide-white/10' : 'grid grid-cols-1';
            }
            const previewPanel = mdPreview?.parentElement as HTMLElement | null;
            if (previewPanel) previewPanel.style.display = splitMode ? '' : 'none';
            toggleBtn.innerHTML = splitMode 
                ? '<span class="material-symbols-outlined text-[14px]">visibility</span> Vista Previa' 
                : '<span class="material-symbols-outlined text-[14px]">edit</span> Escritura';
        });

    if(form && submitBtn && statusMsg) {
