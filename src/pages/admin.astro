                    set('subtitle',    r.subtitle);
                    set('rating',      String(r.rating));
                    set('year',        r.year);
                    set('director',    r.director);
                    set('duration',    r.duration);
                    set('date',        r.date);
                    set('genre',       r.genre);
                    set('heroImage',   r.heroImage);
                    set('posterImage', r.posterImage);
                    set('author',      r.author);
                    set('trailerUrl',  r.trailerUrl || '');
                    set('finalScore',  r.finalScore);
                    set('streaming',   r.streaming);
                    set('fullReview',  (r.fullReview || []).join('\n\n'));
                    set('cast',        (r.cast || []).map((c: any) => `${c.actor} como ${c.role}`).join('\n'));

