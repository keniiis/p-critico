    .manage-card-btn:hover {
        background: #f43f5e;
        border-color: #f43f5e;
        color: white;
    }
</style>

<script>
    const form = document.getElementById('review-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const statusMsg = document.getElementById('status-msg') as HTMLParagraphElement | null;

        // ── EDITOR VISUAL (RESEÑAS) ───────────────────────────────────
        const mdEditor      = document.getElementById('md-editor') as HTMLTextAreaElement | null;
        const mdPreview     = document.getElementById('md-preview') as HTMLElement | null;
        const toggleBtn     = document.getElementById('toggle-preview') as HTMLButtonElement | null;
        const editorContainer = document.getElementById('editor-container') as HTMLElement | null;

        function renderPreview(text: string): string {
            if (!text.trim()) return '<p class="text-tertiary text-sm italic">Tu crítica se verá así...</p>';
            
            // Dividir por bloques de párrafo (doble salto de línea)
            const blocks = text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p);
            
            return blocks.map(block => {
                // Títulos ###
                if (block.startsWith('###')) {
                    return `<h3 class="article-h3" style="color:white; font-size:1.4rem; font-weight:800; margin-top:1.5rem; margin-bottom:0.5rem;">${block.replace(/^###\s*/, '')}</h3>`;
                }
                if (block.startsWith('##')) {
                    return `<h2 class="article-h2" style="color:white; font-size:1.8rem; font-weight:800; margin-top:2rem; margin-bottom:0.7rem;">${block.replace(/^##\s*/, '')}</h2>`;
                }

                // Detectar Listas Manuales (* o -)
                const lines = block.split('\n');
                const isList = lines.every(l => /^[\*\-]\s+/.test(l.trim()));
                
                if (isList && lines.length > 0) {
                    const items = lines.map(l => {
                        const content = l.replace(/^[\*\-]\s+/, '')
                            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                            .replace(/\*(.*?)\*/g, '<em>$1</em>');
                        return `<li style="display:flex; gap:0.75rem; margin-bottom:0.5rem; color:#a8a8a8;">
                            <span style="color:#f43f5e; font-weight:bold;">—</span>
                            <span>${content}</span>
                        </li>`;
                    }).join('');
                    return `<ul style="list-style:none; padding:0; margin-bottom:1.5rem;">${items}</ul>`;
                }

                // Párrafo normal
                const parsed = block
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\*(.*?)\*/g, '<em>$1</em>');
                return `<p style="color:#a8a8a8; line-height:1.8; margin-bottom:1.5rem;">${parsed}</p>`;
            }).join('');
        }

        // Estrellas Visuales
        const starsInput = document.getElementById('rating-stars-input') as HTMLInputElement | null;
        const starsPreview = document.getElementById('stars-preview') as HTMLElement | null;

        function updateStars(val: number) {
            if (!starsPreview) return;
            let stars = '';
            for (let i = 1; i <= 5; i++) {
                if (val >= i) stars += 'star ';
                else if (val >= i - 0.5) stars += 'star_half ';
                else stars += 'star_outline ';
            }
            starsPreview.innerHTML = stars.split(' ').filter(s => s).map(s => `<span class="material-symbols-outlined">${s}</span>`).join('');
        }

        starsInput?.addEventListener('input', () => updateStars(parseFloat(starsInput.value) || 0));

        if (mdEditor && mdPreview) {
            mdEditor.addEventListener('input', () => {
                mdPreview.innerHTML = renderPreview(mdEditor.value);
            });

            // Proxy para detectar cambios programáticos (cuando se edita una reseña existente)
            const origDescriptor = Object.getOwnPropertyDescriptor(HTMLTextAreaElement.prototype, 'value');
            if (origDescriptor) {
                Object.defineProperty(mdEditor, 'value', {
                    set(v) {
                        origDescriptor.set!.call(this, v);
                        mdPreview.innerHTML = renderPreview(v);
                    },
                    get() { return origDescriptor.get!.call(this); }
                });
            }
        }

        let splitMode = true;
        toggleBtn?.addEventListener('click', () => {
            splitMode = !splitMode;
            if (editorContainer) {
                editorContainer.className = splitMode ? 'grid grid-cols-2 divide-x divide-white/10' : 'grid grid-cols-1';
            }
            const previewPanel = mdPreview?.parentElement as HTMLElement | null;
            if (previewPanel) previewPanel.style.display = splitMode ? '' : 'none';
            toggleBtn.innerHTML = splitMode 
                ? '<span class="material-symbols-outlined text-[14px]">visibility</span> Vista Previa' 
                : '<span class="material-symbols-outlined text-[14px]">edit</span> Escritura';
        });

    if(form && submitBtn && statusMsg) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Guardando...';
            submitBtn.style.opacity = '0.7';
            submitBtn.style.pointerEvents = 'none';

            const formData = new FormData(e.target as HTMLFormElement);
            
            const getString = (name: string) => (formData.get(name) as string) || '';
            const getNum = (name: string) => parseFloat(getString(name)) || 0;
            
            const platformMappings = [
                { id: 'platform_cines', name: 'Cines', logo: 'data:image/svg+xml;base64,' },
                { id: 'platform_netflix', name: 'Netflix', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_max', name: 'Max', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_disney', name: 'Disney+', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_appletv', name: 'Apple TV', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_prime', name: 'Prime Video', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' }
            ];
            const watchOptions = [];
            for (const plat of platformMappings) {
                if (formData.get(plat.id) === 'on') {
                    watchOptions.push({ name: plat.name, logo: plat.logo });
                }
            }

            const castRaw = getString('cast');
            const cast = castRaw.split('\n').filter(l => l.includes(' como ')).map(l => {
                const [actor, role] = l.split(' como ');
                return { actor: actor.trim(), role: role.trim() };
            });

            const reviewData = {
                title: getString('title'),
                subtitle: getString('subtitle'),
                rating: getNum('rating'),
                year: getString('year'),
                director: getString('director'),
                duration: getString('duration'),
                date: getString('date'),
                genre: getString('genre'),
                heroImage: getString('heroImage'),
                posterImage: getString('posterImage'),
                author: getString('author'),
                fullReview: getString('fullReview').split(/\n\s*\n/).map((p: string) => p.trim()).filter((p: string) => p),
                finalScore: getString('finalScore'),
                scores: [
                    { category: "Fotografía", score: getNum('score_foto'), icon: "movie_filter", desc: getString('desc_foto') },
                    { category: "Actuación", score: getNum('score_actuacion'), icon: "groups", desc: getString('desc_actuacion') },
                    { category: "Banda Sonora", score: getNum('score_sonido'), icon: "audiotrack", desc: getString('desc_sonido') },
                    { category: "Guion", score: getNum('score_guion'), icon: "auto_stories", desc: getString('desc_guion') }
                ],
                cast: cast,
                streaming: getString('streaming') || "Consultar plataformas",
                watchOptions: watchOptions,
                trailerUrl: getString('trailerUrl')
            };

            try {
                const res = await fetch('/api/save-review', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(reviewData)
                });

                const data = await res.json();

                if(data.success) {
                    statusMsg.textContent = "¡Reseña publicada con éxito!";
                    statusMsg.className = "text-center mt-4 text-sm font-bold text-green-400 transition-opacity opacity-100";
                    form.reset();
                    setTimeout(() => {
                        window.location.href = `/reviews/${data.slug}`;
                    }, 2000);
                } else {
                    throw new Error(data.error);
                }
            } catch (err) {
                statusMsg.textContent = "Error al guardar: " + (err instanceof Error ? err.message : String(err));
                statusMsg.className = "text-center mt-4 text-sm font-bold text-red-400 transition-opacity opacity-100";
                
                submitBtn.innerHTML = originalBtnText;
                submitBtn.style.opacity = '1';
                submitBtn.style.pointerEvents = 'all';
            }
        });
        // ── GESTIONAR TAB ──────────────────────────────────────────────
        const tabGestionar   = document.getElementById('tab-gestionar');
        const gestionarPanel = document.getElementById('manage-section');
        const reviewForm     = document.getElementById('review-form');
        const editSlugInput  = document.getElementById('edit-slug') as HTMLInputElement;
        const reviewsList    = document.getElementById('manage-reviews-list');
        const newsListEl     = document.getElementById('manage-news-list');
        const subTabReviews  = document.getElementById('view-reviews');
        const subTabNews     = document.getElementById('view-news');

        // Renderizar Noticias
        function renderNews(newsList: any[]) {
            if (!newsListEl) return;
            newsListEl.innerHTML = newsList.map(item => `
                <div class="manage-card animate-fade-in">
                    <img src="${item.image}" alt="${item.title}" />
                    <div class="manage-card-content">
                        <span class="manage-card-tag">${item.category || 'NOTICIA'}</span>
                        <h3 class="manage-card-title">${item.title}</h3>
                        <p class="manage-card-desc">${item.summary || item.excerpt || ''}</p>
                        <button class="manage-card-btn edit-news-btn" data-slug="${item.slug}">
                            <span class="material-symbols-outlined text-[18px]">edit</span>
                            Editar Noticia
                        </button>
                    </div>
                </div>
            `).join('');

            // Re-vincular eventos de edición
            newsListEl.querySelectorAll('.edit-news-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const slug = (e.currentTarget as HTMLElement).dataset.slug;
                    window.location.href = `/admin/news?edit=${slug}`;
                });
            });
        }

        // Renderizar Reseñas
        function renderReviews(reviewsArray: any[]) {
            if (!reviewsList) return;
            reviewsList.innerHTML = reviewsArray.map(item => `
                <div class="manage-card animate-fade-in">
                    <img src="${item.heroImage || item.image}" alt="${item.title}" />
                    <div class="manage-card-content">
                        <span class="manage-card-tag" style="color: #a78bfa;">${item.genre || 'RESEÑA'} — ${item.finalScore}/10</span>
                        <h3 class="manage-card-title">${item.title}</h3>
                        <p class="manage-card-desc">${item.subtitle || item.synopsis || ''}</p>
                        <button class="manage-card-btn edit-review-btn" data-slug="${item.slug}">
                            <span class="material-symbols-outlined text-[18px]">edit_note</span>
                            Editar Crítica
                        </button>
                    </div>
                </div>
            `).join('');

            // Re-vincular eventos de edición
            wireReviewEdits();
        }

        // Helper: carga tarjetas de reseñas
        async function loadReviews() {
            if (!reviewsList) return;
            reviewsList.innerHTML = '<div class="text-tertiary text-center py-10 col-span-full animate-pulse">Cargando reseñas...</div>';
            try {
                const data = await (await fetch('/api/get-reviews')).json() as Record<string, any>;
                const reviewsArray = Object.entries(data).reverse().map(([slug, r]) => ({ ...r, slug }));
                renderReviews(reviewsArray);
            } catch (err) {
                reviewsList.innerHTML = '<div class="text-red-400 text-center py-10 col-span-full">Error al cargar reseñas</div>';
            }
        }

        // Helper: carga tarjetas de noticias
        async function loadNews() {
            if (!newsListEl) return;
            newsListEl.innerHTML = '<div class="text-tertiary text-center py-10 col-span-full animate-pulse">Cargando noticias...</div>';
            try {
                const res = await fetch('/api/get-news');
                const data = await res.json() as Record<string, any>;
                const newsArray = Object.entries(data).reverse().map(([slug, n]) => ({ ...n, slug }));
                renderNews(newsArray);
            } catch (err) {
                newsListEl.innerHTML = '<div class="text-red-400 text-center py-10 col-span-full">Error al cargar noticias</div>';
            }
        }

        // Sub-pestañas
        subTabReviews?.addEventListener('click', () => {
            reviewsList?.classList.remove('hidden');
            newsListEl?.classList.add('hidden');
            subTabReviews.className = 'px-8 py-3 rounded-xl bg-primary-container text-background font-bold text-sm transition-all shadow-lg';
            subTabNews!.className   = 'px-8 py-3 rounded-xl hover:bg-white/5 text-tertiary font-bold text-sm transition-all';
        });

        subTabNews?.addEventListener('click', () => {
            reviewsList?.classList.add('hidden');
            newsListEl?.classList.remove('hidden');
            subTabNews.className    = 'px-8 py-3 rounded-xl bg-[#f43f5e] text-white font-bold text-sm transition-all shadow-lg';
            subTabReviews!.className = 'px-8 py-3 rounded-xl hover:bg-white/5 text-tertiary font-bold text-sm transition-all';
            loadNews();
        });

        const tabNuevaResena = document.getElementById('tab-nueva-resena');
        
        tabGestionar?.addEventListener('click', async () => {
            gestionarPanel?.classList.remove('hidden');
            reviewForm?.classList.add('hidden');
            
            // Cambiar estilos de pestañas para indicar pestaña activa
            tabNuevaResena?.classList.replace('bg-[#f43f5e]', 'hover:bg-white/5');
            tabNuevaResena?.classList.replace('text-white', 'text-tertiary');
            tabNuevaResena?.classList.remove('shadow-lg', 'shadow-red-500/20');
            
            tabGestionar?.classList.replace('hover:bg-white/5', 'bg-[#f43f5e]');
            tabGestionar?.classList.replace('text-tertiary', 'text-white');
            tabGestionar?.classList.add('shadow-lg', 'shadow-red-500/20');

            await loadReviews();
        });

        // Auto-abrir pestaña gestionar si viene por URL
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('tab') === 'gestionar') {
            tabGestionar?.click();
        }

        function wireReviewEdits() {
            reviewsList?.querySelectorAll('.edit-review-btn').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const slug = (btn as HTMLElement).dataset.slug!;
                    const allData = await (await fetch('/api/get-reviews')).json();
                    const r = allData[slug];

                    gestionarPanel?.classList.add('hidden');
                    reviewForm?.classList.remove('hidden');
                    editSlugInput.value = slug;

                    if (submitBtn) submitBtn.innerHTML = '<span class="material-symbols-outlined">save</span> Actualizar Reseña';

                    const set = (name: string, val: string) => {
                        const el = (reviewForm as HTMLFormElement)?.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;
                        if (el) el.value = val ?? '';
                    };
                    set('title',       r.title);
                    set('subtitle',    r.subtitle);
                    set('rating',      String(r.rating));
                    set('year',        r.year);
                    set('director',    r.director);
                    set('duration',    r.duration);
                    set('date',        r.date);
                    set('genre',       r.genre);
                    set('heroImage',   r.heroImage);
                    set('posterImage', r.posterImage);
                    set('author',      r.author);
                    set('trailerUrl',  r.trailerUrl || '');
                    set('finalScore',  r.finalScore);
                    set('streaming',   r.streaming);
                    set('fullReview',  (r.fullReview || []).join('\n\n'));
                    if (starsInput) updateStars(r.rating || 0);
                    set('cast',        (r.cast || []).map((c: any) => `${c.actor} como ${c.role}`).join('\n'));

                    r.scores?.forEach((s: any) => {
                        const map: Record<string, string> = { 'Fotografía': 'foto', 'Actuación': 'actuacion', 'Banda Sonora': 'sonido', 'Guion': 'guion' };
                        const key = map[s.category];
                        if (key) { set(`score_${key}`, String(s.score)); set(`desc_${key}`, s.desc); }
                    });

                    const platMap: Record<string, string> = { 'Cines': 'cines', 'Netflix': 'netflix', 'Max': 'max', 'Disney+': 'disney', 'Apple TV': 'appletv', 'Prime Video': 'prime' };
                    r.watchOptions?.forEach((o: any) => {
                        const key = platMap[o.name];
                        if (key) {
                            const cb = (reviewForm as HTMLFormElement)?.elements.namedItem(`platform_${key}`) as HTMLInputElement;
                            if (cb) cb.checked = true;
                        }
                    });

                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            });
        }


        // Interceptar submit para diferenciar crear vs actualizar
        const originalSubmitHandler = form?.addEventListener;
        form?.addEventListener('submit', async (e) => {
            const editSlug = editSlugInput?.value;
            if (!editSlug) return; // Si no hay slug, deja que el handler original cree nuevo

            e.stopImmediatePropagation();
            e.preventDefault();

            if (!submitBtn || !statusMsg) return;
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Guardando...';
            submitBtn.style.opacity = '0.7';
            submitBtn.style.pointerEvents = 'none';

            const formData = new FormData(e.target as HTMLFormElement);
            const getString = (name: string) => (formData.get(name) as string) || '';
            const getNum    = (name: string) => parseFloat(getString(name)) || 0;

            const platformMappings = [
                { id: 'platform_cines', name: 'Cines', logo: 'data:image/svg+xml;base64,' },
                { id: 'platform_netflix', name: 'Netflix', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_max', name: 'Max', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_disney', name: 'Disney+', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_appletv', name: 'Apple TV', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' },
                { id: 'platform_prime', name: 'Prime Video', logo: 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0id2hpdGUiPjxwYXRoIGQ9Ik0yMSAzSDNjLTEuMSAwLTIgLjktMiAydjEyYzAgMS4xLjkgMiAyIDJoNXYyaDh2LTJoNWMxLjEgMCAxLjk5LS45IDEuOTktMkwyMyA1YzAtMS4xLS45LTItMi0yem0wIDE0SDNWNWgxOHYxMnptLTUtNmwtNyA0Vjd6Ii8+PC9zdmc+' }
            ];
            const watchOptions: any[] = [];
            for (const plat of platformMappings) {
                if (formData.get(plat.id) === 'on') watchOptions.push({ name: plat.name, logo: plat.logo });
            }
            const castRaw = getString('cast');
            const cast = castRaw.split('\n').filter((l: string) => l.includes(' como ')).map((l: string) => {
                const [actor, role] = l.split(' como ');
                return { actor: actor.trim(), role: role.trim() };
            });

            const updatedData = {
                title: getString('title'), subtitle: getString('subtitle'),
                rating: getNum('rating'), year: getString('year'),
                director: getString('director'), duration: getString('duration'),
                date: getString('date'), genre: getString('genre'),
                heroImage: getString('heroImage'), posterImage: getString('posterImage'),
                author: getString('author'), trailerUrl: getString('trailerUrl'),
                fullReview: getString('fullReview').split(/\n\s*\n/).map((p: string) => p.trim()).filter((p: string) => p),
                finalScore: getString('finalScore'), streaming: getString('streaming'),
                scores: [
                    { category: 'Fotografía',   score: getNum('score_foto'),       icon: 'movie_filter', desc: getString('desc_foto') },
                    { category: 'Actuación',     score: getNum('score_actuacion'),  icon: 'groups',       desc: getString('desc_actuacion') },
                    { category: 'Banda Sonora',  score: getNum('score_sonido'),     icon: 'audiotrack',   desc: getString('desc_sonido') },
                    { category: 'Guion',         score: getNum('score_guion'),      icon: 'auto_stories', desc: getString('desc_guion') }
                ],
                cast, watchOptions
            };

            try {
                const res = await fetch('/api/update-review', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ slug: editSlug, data: updatedData })
                });
                const result = await res.json();
                if (result.success) {
                    statusMsg!.textContent = '¡Reseña actualizada con éxito!';
                    statusMsg!.className = 'text-center mt-4 text-sm font-bold text-green-400 transition-opacity opacity-100';
                    editSlugInput.value = '';
                    setTimeout(() => { window.location.href = `/reviews/${editSlug}`; }, 1500);
                } else { throw new Error(result.error); }
            } catch (err) {
                statusMsg!.textContent = 'Error: ' + (err instanceof Error ? err.message : String(err));
                statusMsg!.className = 'text-center mt-4 text-sm font-bold text-red-400 transition-opacity opacity-100';
                submitBtn.innerHTML = originalBtnText;
                submitBtn.style.opacity = '1';
                submitBtn.style.pointerEvents = 'all';
            }
        }, true); // capture:true para ejecutarse antes del handler original
    }
</script>
