---
import Layout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ReviewCard from '../components/ReviewCard.astro';

import rawReviewsData from '../data/reviews.json';

// Cargar dinámicamente desde el JSON
const reviews = Object.entries(rawReviewsData).map(([slug, data]) => ({
    slug,
    movie: data.title,
    rating: data.rating,
    image: (data as any).heroImage,
    excerpt: (data as any).fullReview[0] || (data as any).subtitle,
    author: data.author,
    featured: false
}));
---

<Layout title="Críticas de Cine - Paralaje Crítico">
    <Navbar active="reviews" />

    <main class="flex-grow pt-32 pb-20">
        <div class="max-w-container-max mx-auto px-margin">
            <!-- Header -->
            <header class="mb-16">
                <h1 class="font-display-lg text-display-lg text-on-surface text-gradient mb-4">Críticas de Cine</h1>
                <p class="text-tertiary font-body-lg text-lg max-w-2xl leading-relaxed">
                    Nuestros análisis definitivos sobre los últimos estrenos y clásicos de siempre. Profundizamos en la dirección, las actuaciones y el arte cinematográfico.
                </p>
                
                <!-- Filter Bar Temporarily Removed -->
            </header>

            <!-- Reviews Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {reviews.map(review => (
                    <ReviewCard 
                        movie={review.movie}
                        rating={review.rating}
                        image={review.image}
                        excerpt={review.excerpt}
                        author={review.author}
                        featured={review.featured}
                        slug={review.slug}
                    />
                ))}
            </div>

            <!-- Pagination Temporarily Removed -->
        </div>
    </main>

    <Footer />
</Layout>
