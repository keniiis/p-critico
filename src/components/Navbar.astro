---
interface Props {
    active?: "home" | "news" | "reviews" | "films";
}

const { active = "home" } = Astro.props;

import reviewsJson from '../data/reviews.json';
import newsJson from '../data/news.json';

// Índice de búsqueda dinámico generado desde los archivos JSON
const searchIndex = [
    ...Object.entries(reviewsJson).map(([slug, review]) => ({
        title: (review as any).title,
        slug: `/reviews/${slug}`,
        type: "Reseña"
    })),
    ...Object.entries(newsJson).map(([slug, news]) => ({
        title: (news as any).title,
        slug: `/news/${slug}`,
        type: "Noticia"
    }))
];

const linkClass =
    "text-tertiary font-medium hover:text-on-surface transition-colors active:scale-95 transition-transform hover:opacity-80 transition-opacity duration-300";
const activeClass =
    "text-on-surface border-b-2 border-primary-container pb-1 font-bold active:scale-95 transition-transform hover:opacity-80 transition-opacity duration-300";
---

<nav
    class="fixed top-0 w-full z-50 h-20 bg-surface-container-lowest/80 backdrop-blur-xl border-b border-white/10 shadow-2xl shadow-black/50 transition-all duration-300"
>
    <div
        class="w-full max-w-container-max mx-auto h-full flex justify-between items-center px-margin relative"
    >
        <!-- Left: Logo -->
        <div class="z-10">
            <a
                class="text-2xl font-black tracking-tighter uppercase text-on-surface"
                href="/">PARALAJE CRÍTICO</a
            >
        </div>

        <!-- Center: Menu -->
        <div
            class="hidden md:flex items-center gap-10 font-inter antialiased tracking-tight absolute left-1/2 -translate-x-1/2 h-full"
        >
            <a class={active === "home" ? activeClass : linkClass} href="/">Inicio</a>
            <a class={active === "news" ? activeClass : linkClass} href="/news">Noticias</a>
            <a class={active === "reviews" ? activeClass : linkClass} href="/reviews">Reseñas</a>
        </div>

        <!-- Right: Search -->
        <div class="flex items-center gap-6 z-10">
            <div class="relative hidden md:block" id="search-container">
                <span
                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-tertiary text-[20px]"
                    >search</span
                >
                <input
                    id="search-input"
                    class="bg-surface-container-high border-[0.5px] border-white/10 text-on-surface font-body-lg text-body-lg rounded-full py-2 pl-10 pr-4 w-64 focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-all placeholder:text-tertiary"
                    placeholder="Buscar..."
                    type="text"
                    autocomplete="off"
                />
                
                <!-- Instant Results Dropdown (Solid Background) -->
                <div 
                    id="search-results" 
                    class="hidden absolute top-full right-0 mt-4 w-[350px] bg-surface-container-high rounded-xl overflow-hidden shadow-2xl border border-white/10 animate-in fade-in slide-in-from-top-2 duration-200 z-50"
                >
                    <div class="max-h-[400px] overflow-y-auto p-2" id="results-list">
                        <!-- Results injected here -->
                    </div>
                </div>
            </div>
            <!-- Mobile Menu Toggle Button -->
            <button id="mobile-menu-btn" class="md:hidden text-on-surface hover:text-primary-container transition-colors p-2 flex items-center justify-center">
                <span class="material-symbols-outlined text-[28px]">menu</span>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-background/95 backdrop-blur-2xl z-[60] hidden flex-col justify-center items-center gap-10 font-headline-md text-4xl">
    <button id="mobile-menu-close" class="absolute top-6 right-6 text-tertiary hover:text-white transition-colors p-2">
        <span class="material-symbols-outlined text-[36px]">close</span>
    </button>
    <a class={`hover:text-primary-container transition-colors ${active === "home" ? "text-primary-container font-bold" : "text-on-surface"}`} href="/">Inicio</a>
    <a class={`hover:text-primary-container transition-colors ${active === "news" ? "text-primary-container font-bold" : "text-on-surface"}`} href="/news">Noticias</a>
    <a class={`hover:text-primary-container transition-colors ${active === "reviews" ? "text-primary-container font-bold" : "text-on-surface"}`} href="/reviews">Reseñas</a>
    
    <!-- Mobile Search -->
    <div class="w-full px-8 mt-4 relative" id="mobile-search-container">
        <span class="material-symbols-outlined absolute left-11 top-1/2 -translate-y-1/2 text-tertiary text-[20px]">search</span>
        <input
            id="mobile-search-input"
            class="bg-surface-container-high border-[0.5px] border-white/10 text-on-surface font-body-lg text-lg rounded-full py-3 pl-12 pr-4 w-full focus:outline-none focus:border-white/30 transition-all placeholder:text-tertiary"
            placeholder="Buscar..."
            type="text"
            autocomplete="off"
        />
        <div 
            id="mobile-search-results" 
            class="hidden absolute top-full left-8 right-8 mt-2 bg-surface-container-high rounded-xl overflow-hidden shadow-2xl border border-white/10 z-50"
        >
            <div class="max-h-[300px] overflow-y-auto p-2" id="mobile-results-list"></div>
        </div>
    </div>
</div>

<script define:vars={{ searchIndex }}>
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const resultsList = document.getElementById('results-list');
    const searchContainer = document.getElementById('search-container');
    
    const mobileSearchInput = document.getElementById('mobile-search-input');
    const mobileSearchResults = document.getElementById('mobile-search-results');
    const mobileResultsList = document.getElementById('mobile-results-list');

    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    function handleSearch(input, results, list) {
        if (!input) return;
        input.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            
            if (query.length < 2) {
                results.classList.add('hidden');
                return;
            }

            const filtered = searchIndex.filter(item => 
                item.title.toLowerCase().includes(query) || 
                item.type.toLowerCase().includes(query)
            );

            if (filtered.length > 0) {
                list.innerHTML = filtered.map(item => `
                    <a href="${item.slug}" class="flex flex-col p-3 hover:bg-white/5 rounded-lg transition-colors group">
                        <span class="text-[10px] font-bold text-primary-container uppercase tracking-widest mb-1">${item.type}</span>
                        <span class="text-on-surface font-medium group-hover:text-white transition-colors text-sm">${item.title}</span>
                    </a>
                `).join('');
                results.classList.remove('hidden');
            } else {
                list.innerHTML = `
                    <div class="p-4 text-center text-tertiary text-sm italic">
                        No se encontraron resultados
                    </div>
                `;
                results.classList.remove('hidden');
            }
        });
    }

    handleSearch(searchInput, searchResults, resultsList);
    handleSearch(mobileSearchInput, mobileSearchResults, mobileResultsList);

    // Mobile Menu Toggle
    if (mobileMenuBtn && mobileMenuClose && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.remove('hidden');
            mobileMenu.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });

        mobileMenuClose.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
            document.body.style.overflow = '';
            // Clear mobile search on close
            if(mobileSearchInput) mobileSearchInput.value = '';
            if(mobileSearchResults) mobileSearchResults.classList.add('hidden');
        });
    }

    // Close when clicking outside
    document.addEventListener('click', (e) => {
        if (!searchContainer.contains(e.target)) {
            searchResults.classList.add('hidden');
        }
    });

    // ESC key to close
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            searchResults.classList.add('hidden');
            searchInput.blur();
        }
    });
</script>

<style>
    #results-list::-webkit-scrollbar {
        width: 4px;
    }
    #results-list::-webkit-scrollbar-track {
        background: transparent;
    }
    #results-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
</style>
